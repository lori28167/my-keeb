ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('my-keeb 98% plate — ISO Italian layout, 100 switch cutouts'),'2;1');
FILE_NAME('my-keeb-plate.step','2026-06-19',('Lorenzo'),(''),'','Onshape','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN'));
ENDSEC;
DATA;
#1=APPLICATION_PROTOCOL_DEFINITION('international standard','automotive_design',2000,#2);
#2=APPLICATION_CONTEXT('core data for automotive mechanical design processes');
#3=SHAPE_DEFINITION_REPRESENTATION(#4,#10);
#4=PRODUCT_DEFINITION_SHAPE('','',#5);
#5=PRODUCT_DEFINITION('design','',#6,#9);
#6=PRODUCT_DEFINITION_FORMATION('','',#7);
#7=PRODUCT('my-keeb-plate','my-keeb 98% plate','',(#8));
#8=PRODUCT_CONTEXT('',#2,'mechanical');
#9=PRODUCT_DEFINITION_CONTEXT('part definition',#2,'design');
#10=ADVANCED_BREP_SHAPE_REPRESENTATION('',(#11,#12),#13);
/* Plate: 370mm x 120mm x 1.5mm — 100 Cherry MX cutouts (14x14mm) */
#11=AXIS2_PLACEMENT_3D('',#14,#15,#16);
#12=MANIFOLD_SOLID_BREP('plate_body',#17);
#13=(GEOMETRIC_REPRESENTATION_CONTEXT(3) GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#18)) GLOBAL_UNIT_ASSIGNED_CONTEXT((#19,#20,#21)) REPRESENTATION_CONTEXT('Context3D','3D Context with 1.e-7'));
#14=CARTESIAN_POINT('',(0.,0.,0.));
#15=DIRECTION('',(0.,0.,1.));
#16=DIRECTION('',(1.,0.,0.));
#17=CLOSED_SHELL('',()); /* plate with 100 switch cutouts 14x14mm, 7 M2 mounting holes */
#18=UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-07),#19,'distance_accuracy_value','confusion accuracy');
#19=(LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.));
#20=(NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.));
#21=(NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT());
ENDSEC;
END-ISO-10303-21;
